extension/types/attractor-schema.ts
.DS_Store
.gitnexus
# Worker scratch dirs (codex feasibility studies, ad-hoc experiments)
extension/.tmp/
# Claude Code agent worktrees — temporary git worktrees created by isolation:"worktree"
.claude/worktrees/
# Runtime data leaks — these belong in PICKLE_DATA_ROOT (~/.local/share/pickle-rick/),
# but workers occasionally write them to the source repo cwd.
current_sessions.json
# User-specific Claude Code files (memories, conversations)
.claude/pickle-rick/
.claude/projects/
.claude/todos/
# Cron/scheduler session metadata — written by Claude Code at session start; per-machine state
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json
# Pipeline session lifecycle dirs — belong in PICKLE_DATA_ROOT (~/.local/share/pickle-rick/),
# but a worker with a mis-resolved cwd occasionally writes them into the source repo.
/sessions/
# R-SSDF-FW (cb5e4247): in-tree TASK_NOTES mirror at <working_dir>/.pickle-rick/sessions/<hash>/
# Runtime data only — never committed.
.pickle-rick/
# .claude/commands/ and .claude/skills/ are tracked — they're the product
/scripts/
activity/
.codex/
# Runtime test debris — non-deterministic file regenerated on each run
bundle/ac-dr-02.runtime.json
