{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/pickle-rick/extension/hooks/dispatch.js stop-hook"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/pickle-rick/extension/hooks/dispatch.js config-protection"
          }
        ]
      }
    ]
  }
}
