digraph "emit_helper_microverse" {
  graph [goal="exercise extracted emit helper topology", label="emit-helper-microverse: exercise extracted emit helper topology", rankdir="LR", retry_target="fix_types"]
  /* DEFENSE MATRIX
   * competitive: false
   * adversarial: false
   * specDriven: NONE
   * guardrails: P0c
   * permissions: none
   */
  start [shape="Mdiamond"]
  setup_deps [label="setup_deps", shape="parallelogram", tool_command="cd ${WORKING_DIR} && npm install 2>&1 || pnpm install 2>&1 || yarn install 2>&1"]
  capture_baseline [label="capture_baseline", read_only="true", shape="parallelogram", tool_command="cd ${WORKING_DIR} && (npx tsc --noEmit 2>&1 | grep -c 'error TS' > /tmp/baseline_ts_errors.txt || echo 0 > /tmp/baseline_ts_errors.txt) && (npx eslint src/ 2>&1 | grep -c 'error' > /tmp/baseline_lint_errors.txt || echo 0 > /tmp/baseline_lint_errors.txt)"]
  commit_baseline [label="commit_baseline", shape="parallelogram"]
  baseline [label="baseline latency", shape="parallelogram"]
  optimize [label="optimize latency"]
  measure [label="measure latency"]
  compare [direction="reduce", label="compare", max_visits="8", shape="diamond", target="50"]
  check [label="check", shape="diamond"]
  exit [label="exit", shape="Msquare"]
  start -> setup_deps
  setup_deps -> capture_baseline
  capture_baseline -> commit_baseline
  commit_baseline -> baseline
  baseline -> optimize
  optimize -> measure
  measure -> compare
  compare -> optimize [condition="outcome=miss", label="miss"]
  compare -> check [condition="outcome=hit", label="hit"]
  check -> exit [condition="outcome=accept", label="accept"]
  check -> optimize [condition="outcome=reject", label="reject"]
}