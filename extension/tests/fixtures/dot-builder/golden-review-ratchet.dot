digraph "snap_review_ratchet" {
  graph [acceptance_criteria="context.reviewed_done=true", goal="review ratchet snapshot baseline", label="snap-review-ratchet: review ratchet snapshot baseline", rankdir="LR", retry_target="fix_types"]
  /* DEFENSE MATRIX
   * competitive: false
   * adversarial: false
   * specDriven: NONE
   * guardrails: P0c, P6b, P10, P13, P14, P15, P25
   * permissions: auto
   */
  start [shape="Mdiamond"]
  setup_deps [label="setup_deps", shape="parallelogram", tool_command="cd ${WORKING_DIR} && npm install 2>&1 || pnpm install 2>&1 || yarn install 2>&1"]
  capture_baseline [label="capture_baseline", read_only="true", shape="parallelogram", tool_command="cd ${WORKING_DIR} && (npx tsc --noEmit 2>&1 | grep -c 'error TS' > /tmp/baseline_ts_errors.txt || echo 0 > /tmp/baseline_ts_errors.txt) && (npx eslint src/ 2>&1 | grep -c 'error' > /tmp/baseline_lint_errors.txt || echo 0 > /tmp/baseline_lint_errors.txt)"]
  // ========== PHASE 1: reviewed ==========
  impl_reviewed [allowed_paths="src/", class="codergen", escalate_on="package.json,*.lock,*.config.*", label="implement reviewed", max_visits="5", permission_mode="auto", thread_id="phase_1", timeout="10m"]
  scope_check_reviewed [class="review", label="Compare git diff against phase prompt. Flag files modified outside allowed_paths. Output STATUS: SUCCESS | FAIL.", read_only="true", shape="parallelogram", thread_id="phase_1"]
  check_progress_reviewed [label="check_progress", max_visits="3", read_only="true", shape="parallelogram", thread_id="phase_1", tool_command="cd ${WORKING_DIR} && [ $(git status --porcelain | wc -l) -gt 0 ] && echo 'STATUS: SUCCESS' || echo 'STATUS: FAIL'"]
  verify_lint_reviewed [label="verify_lint: BASELINE from cat baseline_lint_errors; CURRENT lint error count -le BASELINE", shape="parallelogram", thread_id="phase_1", tool_command="[ $(npx eslint src/ 2>&1 | grep -c error || echo 0) -le $(cat /tmp/baseline_lint_errors.txt 2>/dev/null || echo 0) ]"]
  verify_types_reviewed [label="verify_types: BASELINE from cat baseline_ts_errors; CURRENT TS error count -le BASELINE", thread_id="phase_1", tool_command="[ $(npx tsc --noEmit 2>&1 | grep -c error || echo 0) -le $(cat /tmp/baseline_ts_errors.txt 2>/dev/null || echo 0) ]"]
  conformance_reviewed [class="review", context_on_success="reviewed_done=true", label="Review the implementation against the phase spec and PRD requirements. Check: correct files modified, API contracts match, no regressions. Output STATUS: SUCCESS | FAIL.", read_only="true", thread_id="phase_1", timeout="15m"]
  test_reviewed [label="test reviewed", max_visits="5", retry_target="impl_reviewed", shape="diamond"]
  fix_reviewed [allowed_paths="src/", class="codergen", escalate_on="package.json,*.lock,*.config.*", label="fix reviewed", max_visits="5", permission_mode="auto", thread_id="phase_1", timeout="30m"]
  audit [label="audit", read_only="true", shape="parallelogram", tool_command="cd ${WORKING_DIR} && (npx tsc --noEmit 2>&1 || true) && (npx eslint src/ --max-warnings=-1 2>&1 || true) && (npm test 2>&1 || true)"]
  verify_typecheck [context_on_success="types_compile=true", label="verify_typecheck", max_visits="5", retry_target="fix_types", shape="parallelogram", timeout="30m", tool_command="cd ${WORKING_DIR} && npx tsc --noEmit"]
  fix_types [allowed_paths="src/", class="codergen", escalate_on="package.json,*.lock,*.config.*", label="Fix ONLY type errors reported by tsc --noEmit", max_visits="5", permission_mode="auto", timeout="30m"]
  verify_lint [context_on_success="lint_clean=true", label="verify_lint", max_visits="5", retry_target="fix_lint", shape="parallelogram", timeout="30m", tool_command="cd ${WORKING_DIR} && npx eslint src/ --max-warnings=-1"]
  fix_lint [allowed_paths="src/", class="codergen", escalate_on="package.json,*.lock,*.config.*", label="Fix ONLY lint errors reported by eslint", max_visits="5", permission_mode="auto", timeout="30m"]
  verify_tests [context_on_success="cli_contract=true,determinism=true,reviewed_done=true,tests_pass=true,validation_rules=true", label="verify_tests", max_visits="5", retry_target="fix_tests", shape="parallelogram", timeout="30m", tool_command="cd ${WORKING_DIR} && npm test"]
  fix_tests [allowed_paths="src/", class="codergen", escalate_on="package.json,*.lock,*.config.*", label="Fix ONLY failing tests reported by npm test", max_visits="5", permission_mode="auto", timeout="30m"]
  regression_check [label="regression_check", shape="parallelogram", timeout="30m", tool_command="cd ${WORKING_DIR} && npx tsc --noEmit && npx eslint src/ --max-warnings=-1 && npm test"]
  quality_review [class="review", label="Final quality review: verify all acceptance criteria met, no regressions, code is clean. Output STATUS: SUCCESS | FAIL.", read_only="true", timeout="15m"]
  review_pass_1 [label="review pass 1", shape="component"]
  review_pass_2 [label="review pass 2", shape="component"]
  review_pass_3 [label="review pass 3", shape="component"]
  review_merge [label="review_merge", ratchet_count="3", shape="tripleoctagon"]
  fix_review [label="fix_review", shape="parallelogram"]
  exit [label="exit", shape="Msquare"]
  start -> setup_deps
  setup_deps -> capture_baseline
  capture_baseline -> impl_reviewed
  impl_reviewed -> scope_check_reviewed
  scope_check_reviewed -> check_progress_reviewed
  check_progress_reviewed -> verify_lint_reviewed
  verify_lint_reviewed -> verify_types_reviewed
  verify_types_reviewed -> conformance_reviewed
  conformance_reviewed -> test_reviewed
  test_reviewed -> fix_reviewed [condition="outcome=fail", label="fail"]
  fix_reviewed -> impl_reviewed
  test_reviewed -> audit [condition="outcome=success", label="pass"]
  audit -> verify_typecheck
  verify_typecheck -> fix_types [condition="outcome=fail", label="fail"]
  fix_types -> verify_typecheck
  verify_typecheck -> verify_lint [condition="outcome=success", label="pass"]
  verify_lint -> fix_lint [condition="outcome=fail", label="fail"]
  fix_lint -> verify_lint
  verify_lint -> verify_tests [condition="outcome=success", label="pass"]
  verify_tests -> fix_tests [condition="outcome=fail", label="fail"]
  fix_tests -> verify_tests
  verify_tests -> regression_check [condition="outcome=success", label="pass"]
  regression_check -> fix_types [condition="outcome=fail", label="fail"]
  regression_check -> quality_review [condition="outcome=success", label="pass"]
  quality_review -> exit [condition="outcome=success", label="pass"]
  quality_review -> fix_types [condition="outcome=fail", label="fail"]
  regression_check -> setup_deps [loop_restart="true"]
  review_pass_1 -> review_pass_2
  review_pass_2 -> review_pass_3
  review_pass_3 -> review_merge
  review_merge -> exit [condition="outcome=success", label="pass"]
  review_merge -> fix_review [condition="outcome=fail", label="fail"]
  fix_review -> review_pass_1
}