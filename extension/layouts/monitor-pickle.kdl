layout {
    tab name="runner" {
        pane command="sh" {
            args "-c" "exec node $PICKLE_EXTENSION_ROOT/extension/bin/mux-runner.js $PICKLE_SESSION_ROOT"
            cwd "$PICKLE_CWD"
        }
    }
    tab name="monitor" focus=true {
        pane split_direction="vertical" {
            pane split_direction="horizontal" {
                pane command="sh" {
                    args "-c" "exec node $PICKLE_EXTENSION_ROOT/extension/bin/monitor.js $PICKLE_SESSION_ROOT"
                }
                pane command="sh" {
                    args "-c" "exec node $PICKLE_EXTENSION_ROOT/extension/bin/log-watcher.js $PICKLE_SESSION_ROOT"
                }
            }
            pane size="33%" command="sh" {
                args "-c" "exec node $PICKLE_EXTENSION_ROOT/extension/bin/morty-watcher.js $PICKLE_SESSION_ROOT"
            }
        }
    }
}
