{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ActivityEventPayloadSchema",
  "description": "Required-field schemas for 11 new activity event types (AC-EVENT-PAYLOAD-01). Validators read definitions[eventType] to check required top-level and nested gate_payload fields.",
  "definitions": {
    "backendEnum": {
      "type": "string",
      "enum": ["claude", "codex", "hermes"]
    },
    "backendResolutionSourceEnum": {
      "type": "string",
      "enum": ["state", "env", "settings", "default", "refinement-lock", "cli-flag-override"]
    },
    "workerBackendResolutionSourceEnum": {
      "type": "string",
      "enum": ["worker_backend", "backend", "env_lock"]
    },
    "worker_spawn_backend_resolved": {
      "type": "object",
      "required": ["event", "ts", "backend", "source", "pid"],
      "properties": {
        "event": { "type": "string", "const": "worker_spawn_backend_resolved" },
        "ts": { "type": "string" },
        "backend": { "$ref": "#/definitions/backendEnum" },
        "source": { "$ref": "#/definitions/backendResolutionSourceEnum" },
        "pid": { "type": "integer" }
      }
    },
    "worker_spawn_backend_mismatch": {
      "type": "object",
      "required": ["event", "ts", "source", "pid", "ticket", "session", "resolved_backend"],
      "properties": {
        "event": { "type": "string", "const": "worker_spawn_backend_mismatch" },
        "ts": { "type": "string" },
        "source": { "$ref": "#/definitions/backendResolutionSourceEnum" },
        "pid": { "type": "integer" },
        "ticket": { "type": "string" },
        "session": { "type": "string" },
        "resolved_backend": { "$ref": "#/definitions/backendEnum" },
        "state_backend": { "$ref": "#/definitions/backendEnum" }
      }
    },
    "worker_spawn_backend_override": {
      "type": "object",
      "required": ["event", "ts", "backend"],
      "properties": {
        "event": { "type": "string", "const": "worker_spawn_backend_override" },
        "ts": { "type": "string" },
        "backend": { "$ref": "#/definitions/backendEnum" }
      }
    },
    "subtool_backend_override": {
      "type": "object",
      "required": ["event", "ts", "backend"],
      "properties": {
        "event": { "type": "string", "const": "subtool_backend_override" },
        "ts": { "type": "string" },
        "backend": { "$ref": "#/definitions/backendEnum" }
      }
    },
    "worker_partial_lifecycle_exit": {
      "type": "object",
      "required": ["event", "ts", "ticket", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "worker_partial_lifecycle_exit" },
        "ts": { "type": "string" },
        "ticket": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["artifacts_missing", "session_log_size"],
          "properties": {
            "artifacts_missing": {
              "type": "array",
              "items": { "type": "string" }
            },
            "session_log_size": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "cap_check_skipped_stale_cache": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "cap_check_skipped_stale_cache" },
        "ts": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": [
            "current_ticket",
            "current_ticket_max_iterations",
            "current_ticket_budget_start_iteration",
            "current_ticket_tier"
          ],
          "properties": {
            "current_ticket": {},
            "current_ticket_max_iterations": {},
            "current_ticket_budget_start_iteration": {},
            "current_ticket_tier": {}
          }
        }
      }
    },
    "pipeline_auto_resumed": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "pipeline_auto_resumed" },
        "ts": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["retry_index", "ticket_id", "session_done_count_at_retry"],
          "properties": {
            "retry_index": { "type": "integer", "minimum": 0 },
            "ticket_id": { "type": "string" },
            "session_done_count_at_retry": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "bundle_bootstrap_exemption_applied": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "bundle_bootstrap_exemption_applied" },
        "ts": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["skip_readiness_reason", "skip_ticket_audit_reason"],
          "properties": {
            "skip_readiness_reason": { "type": "string" },
            "skip_ticket_audit_reason": { "type": "string" }
          }
        }
      }
    },
    "ticket_audit_bypassed": {
      "type": "object",
      "required": ["event", "ts", "reason"],
      "properties": {
        "event": { "type": "string", "const": "ticket_audit_bypassed" },
        "ts": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "ticket_audit_failed": {
      "type": "object",
      "required": ["event", "ts"],
      "properties": {
        "event": { "type": "string", "const": "ticket_audit_failed" },
        "ts": { "type": "string" },
        "session": { "type": "string" }
      }
    },
    "ticket_audit_manual_edit": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "ticket_audit_manual_edit" },
        "ts": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["edit_count"],
          "properties": {
            "edit_count": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "smoke_gate_bypassed": {
      "type": "object",
      "required": ["event", "ts", "reason"],
      "properties": {
        "event": { "type": "string", "const": "smoke_gate_bypassed" },
        "ts": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "bundle_2026_05_04_closer_done": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "bundle_2026_05_04_closer_done" },
        "ts": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["release_url"],
          "properties": {
            "release_url": { "type": "string" }
          }
        }
      }
    },
    "install_sh_parity_check": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "install_sh_parity_check" },
        "ts": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["files_checked", "mismatches", "status"],
          "properties": {
            "files_checked": { "type": "array", "items": { "type": "string" } },
            "mismatches": { "type": "array", "items": { "type": "string" } },
            "status": { "type": "string", "enum": ["pass", "fail"] }
          }
        }
      }
    },
    "worker_backend_resolved": {
      "type": "object",
      "required": ["event", "ts", "backend", "worker_backend", "source"],
      "properties": {
        "event": { "type": "string", "const": "worker_backend_resolved" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "backend": { "$ref": "#/definitions/backendEnum" },
        "worker_backend": {
          "anyOf": [
            { "$ref": "#/definitions/backendEnum" },
            { "type": "null" }
          ]
        },
        "source": { "$ref": "#/definitions/workerBackendResolutionSourceEnum" }
      }
    },
    "completion_commit_auto_filled": {
      "type": "object",
      "required": ["event", "ts", "ticket_id", "sha", "helper"],
      "properties": {
        "event": { "type": "string", "const": "completion_commit_auto_filled" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "sha": { "type": "string" },
        "helper": { "type": "string" }
      }
    },
    "completion_commit_inferred_from_git": {
      "type": "object",
      "required": ["event", "ts", "ticket_id", "sha"],
      "properties": {
        "event": { "type": "string", "const": "completion_commit_inferred_from_git" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "sha": { "type": "string" }
      }
    },
    "phantom_done_detected": {
      "type": "object",
      "required": ["event", "ts", "ticket", "completion_commit_present"],
      "properties": {
        "event": { "type": "string", "const": "phantom_done_detected" },
        "ts": { "type": "string" },
        "ticket": { "type": "string" },
        "completion_commit_present": { "type": "boolean" },
        "source": { "type": "string" },
        "session": { "type": "string" }
      }
    },
    "standup_session_dropped": {
      "type": "object",
      "required": ["event", "ts", "session_name", "drop_reason"],
      "properties": {
        "event": { "type": "string", "const": "standup_session_dropped" },
        "ts": { "type": "string" },
        "session_name": { "type": "string" },
        "drop_reason": { "type": "string" }
      }
    },
    "worker_lint_gate_passed": {
      "type": "object",
      "required": ["event", "ts", "ticket_id", "file_list"],
      "properties": {
        "event": { "type": "string", "const": "worker_lint_gate_passed" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "file_list": { "type": "array", "items": { "type": "string" } }
      }
    },
    "worker_lint_gate_failed": {
      "type": "object",
      "required": ["event", "ts", "ticket_id", "lint_errors", "tsc_errors", "file_list"],
      "properties": {
        "event": { "type": "string", "const": "worker_lint_gate_failed" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "lint_errors": { "type": "integer", "minimum": 0 },
        "tsc_errors": { "type": "integer", "minimum": 0 },
        "file_list": { "type": "array", "items": { "type": "string" } }
      }
    },
    "worker_lint_autofix_applied": {
      "type": "object",
      "required": ["event", "ts", "ticket_id", "file_list"],
      "properties": {
        "event": { "type": "string", "const": "worker_lint_autofix_applied" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "file_list": { "type": "array", "items": { "type": "string" } }
      }
    },
    "worker_completion_commit_announced": {
      "type": "object",
      "required": ["event", "ts", "ticket_id", "sha"],
      "properties": {
        "event": { "type": "string", "const": "worker_completion_commit_announced" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "sha": { "type": "string" }
      }
    },
    "time_cap_disabled_default": {
      "type": "object",
      "required": ["event", "ts"],
      "properties": {
        "event": { "type": "string", "const": "time_cap_disabled_default" },
        "ts": { "type": "string" },
        "session": { "type": "string" },
        "backend": { "$ref": "#/definitions/backendEnum" },
        "prior_value": {}
      }
    },
    "manager_idle_backoff_engaged": {
      "type": "object",
      "required": ["event", "ts", "session", "ticket", "consecutive_wait_turns", "last_worker_pid"],
      "properties": {
        "event": { "type": "string", "const": "manager_idle_backoff_engaged" },
        "ts": { "type": "string" },
        "session": { "type": "string" },
        "ticket": { "type": ["string", "null"] },
        "consecutive_wait_turns": { "type": "integer", "minimum": 3 },
        "last_worker_pid": { "type": ["integer", "null"] }
      }
    },
    "manager_idle_backoff_released": {
      "type": "object",
      "required": ["event", "ts", "session", "ticket", "duration_ms", "release_reason"],
      "properties": {
        "event": { "type": "string", "const": "manager_idle_backoff_released" },
        "ts": { "type": "string" },
        "session": { "type": "string" },
        "ticket": { "type": ["string", "null"] },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "release_reason": {
          "type": "string",
          "enum": ["state_mtime", "worker_exit", "artifact_landed", "fallback_timer"]
        }
      }
    },
    "worker_edit_outside_scope": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "worker_edit_outside_scope" },
        "ts": { "type": "string" },
        "ticket_id": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["scope_json_path", "staged_paths_outside_scope", "head_ref", "suggested_remediation"],
          "properties": {
            "scope_json_path": { "type": "string" },
            "staged_paths_outside_scope": { "type": "array", "items": { "type": "string" } },
            "head_ref": { "type": "string" },
            "suggested_remediation": { "type": "string" }
          }
        }
      }
    },
    "pkgjson_revert_forensic_captured": {
      "type": "object",
      "required": ["event", "ts", "gate_payload"],
      "properties": {
        "event": { "type": "string", "const": "pkgjson_revert_forensic_captured" },
        "ts": { "type": "string" },
        "gate_payload": {
          "type": "object",
          "required": ["forensic_artifact_path", "suspected_hypothesis", "src_version", "deployed_version"],
          "properties": {
            "forensic_artifact_path": { "type": "string" },
            "suspected_hypothesis": { "type": "string" },
            "src_version": { "type": "string" },
            "deployed_version": { "type": "string" }
          }
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/worker_spawn_backend_resolved" },
    { "$ref": "#/definitions/worker_spawn_backend_mismatch" },
    { "$ref": "#/definitions/worker_spawn_backend_override" },
    { "$ref": "#/definitions/subtool_backend_override" },
    { "$ref": "#/definitions/worker_partial_lifecycle_exit" },
    { "$ref": "#/definitions/cap_check_skipped_stale_cache" },
    { "$ref": "#/definitions/pipeline_auto_resumed" },
    { "$ref": "#/definitions/bundle_bootstrap_exemption_applied" },
    { "$ref": "#/definitions/ticket_audit_bypassed" },
    { "$ref": "#/definitions/ticket_audit_failed" },
    { "$ref": "#/definitions/ticket_audit_manual_edit" },
    { "$ref": "#/definitions/smoke_gate_bypassed" },
    { "$ref": "#/definitions/bundle_2026_05_04_closer_done" },
    { "$ref": "#/definitions/install_sh_parity_check" },
    { "$ref": "#/definitions/worker_backend_resolved" },
    { "$ref": "#/definitions/completion_commit_auto_filled" },
    { "$ref": "#/definitions/completion_commit_inferred_from_git" },
    { "$ref": "#/definitions/phantom_done_detected" },
    { "$ref": "#/definitions/worker_lint_gate_passed" },
    { "$ref": "#/definitions/worker_lint_gate_failed" },
    { "$ref": "#/definitions/worker_lint_autofix_applied" },
    { "$ref": "#/definitions/worker_completion_commit_announced" },
    { "$ref": "#/definitions/time_cap_disabled_default" },
    { "$ref": "#/definitions/manager_idle_backoff_engaged" },
    { "$ref": "#/definitions/manager_idle_backoff_released" },
    { "$ref": "#/definitions/worker_edit_outside_scope" },
    { "$ref": "#/definitions/pkgjson_revert_forensic_captured" }
  ]
}
