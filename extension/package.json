{
  "name": "pickle-rick-scripts",
  "version": "1.69.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x",
    "codex": "0.128.0"
  },
  "scripts": {
    "lint": "eslint src/",
    "postinstall": "mkdir -p ../node_modules/.bin && ln -sf $(pwd)/node_modules/.bin/tsc ../node_modules/.bin/tsc",
    "sync-schema": "node bin/sync-schema.js",
    "calibrate:readiness": "node bin/calibrate.js readiness --check",
    "calibrate:correct-course": "node bin/calibrate.js correct-course --check",
    "calibrate:archaeology": "node bin/calibrate.js archaeology --check",
    "test": "npm run test:fast && npm run test:integration",
    "pretest:fast": "bash scripts/audit-test-tiers.sh && bash scripts/audit-test-isolation.sh",
    "test:fast": "node bin/test-runner.js --tier fast",
    "coverage": "c8 --reporter=html --reporter=json-summary --report-dir=coverage node bin/test-runner.js --tier fast",
    "test:integration": "node bin/test-runner.js --tier integration",
    "test:expensive": "node bin/test-runner.js --tier expensive",
    "test:behavioral": "node --test tests/feature-flag-baseline.test.js"
  },
  "_audit": {
    "flatted": "P3-hygiene: GHSA-25h7-pfq9-p65f HIGH (CVSS 7.5) DoS in parse(). Dev-only path: eslint->file-entry-cache->flat-cache->flatted. Not reachable in production. Track for eslint upgrade to resolve transitively.",
    "c8": {
      "version": "11.0.0",
      "notes": "no current public CVE; pinned exact for contract-test stability"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "c8": "11.0.0",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
