{
  "name": "pickle-rick-scripts",
  "version": "1.100.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x",
    "codex": "0.133.0",
    "claude": "2.1.126",
    "gh": "2.88.1"
  },
  "scripts": {
    "lint": "eslint src/",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const dir=path.resolve('../node_modules/.bin');fs.mkdirSync(dir,{recursive:true});const dst=path.join(dir,'tsc');const src=path.resolve('node_modules/.bin/tsc');const tmp=dst+'.tmp.'+process.pid+'.'+Date.now();fs.symlinkSync(src,tmp);fs.renameSync(tmp,dst);\"",
    "sync-schema": "node bin/sync-schema.js",
    "calibrate:readiness": "node bin/calibrate.js readiness --check",
    "calibrate:correct-course": "node bin/calibrate.js correct-course --check",
    "calibrate:archaeology": "node bin/calibrate.js archaeology --check",
    "test": "npm run test:fast && npm run test:integration",
    "pretest:fast": "bash scripts/audit-test-tiers.sh && bash scripts/audit-test-isolation.sh",
    "test:fast": "node bin/test-runner.js --tier fast --test-concurrency=8",
    "coverage": "c8 --reporter=html --reporter=json-summary --report-dir=coverage node bin/test-runner.js --tier fast",
    "coverage:delta": "bash scripts/coverage-delta.sh",
    "test:integration": "npm run test:integration:parallel && npm run test:integration:serial",
    "test:integration:parallel": "node bin/test-runner.js --tier integration --manifest tests/integration/.serial-tests.json --manifest-mode exclude",
    "test:integration:serial": "node bin/test-runner.js --tier integration --manifest tests/integration/.serial-tests.json --manifest-mode include --test-concurrency=1",
    "test:expensive": "node bin/test-runner.js --tier expensive",
    "test:regression-3x": "bash scripts/regression-test-fast-integration-3x.sh",
    "test:behavioral": "node --test tests/feature-flag-baseline.test.js",
    "wire-check": "bash scripts/check-wired.sh"
  },
  "_audit": {
    "flatted": "P3-hygiene: GHSA-25h7-pfq9-p65f HIGH (CVSS 7.5) DoS in parse(). Dev-only path: eslint->file-entry-cache->flat-cache->flatted. Not reachable in production. Track for eslint upgrade to resolve transitively.",
    "c8": {
      "version": "11.0.0",
      "notes": "no current public CVE; pinned exact for contract-test stability"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "c8": "11.0.0",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
