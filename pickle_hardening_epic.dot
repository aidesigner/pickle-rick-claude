digraph pickle_hardening_epic {
    goal = "Harden pickle-rick-claude v1.14.0 against state corruption, process leaks, and build hygiene issues through atomic state management, process lifecycle fixes, integration testing, and defensive coding — producing release-ready v1.15.0"
    label = "pickle-hardening-epic: Pickle Rick Hardening v1.15.0"
    working_dir = "/repos/pickle-rick/pickle-rick-claude"
    default_max_retry = 2
    retry_target = "setup_deps"
    acceptance_criteria = "context.tests_pass=true && context.build_status=passing && context.lint_status=passing"
    model_stylesheet = "* { llm_model: claude-sonnet-4-6; } .critical { llm_model: claude-opus-4-6; reasoning_effort: high; } .review { llm_model: claude-opus-4-6; }"

    start [shape=Mdiamond, label="Begin"]
    setup_deps [shape=parallelogram, tool_command="cd extension && npm install 2>&1", timeout=120s]
    done [shape=Msquare, label="v1.15.0 Released"]

    // ========== PHASE 1: Build Hygiene (F1-F4) ==========

    impl_p1_lockfile [prompt="Phase 1a — Sync package-lock.json and verify flatted CVE (ticket 415adc10). In extension/: 1) Run 'npm install' to regenerate package-lock.json matching package.json v1.14.0+. 2) Run 'npm audit --json' to check flatted CVE. flatted is a transitive devDependency of ESLint via flat-cache — if advisory is dev-only and not HIGH/CRITICAL in production path, document as P3 hygiene (add comment to package.json). If production-path HIGH/CRITICAL, update flatted>=3.4.0. 3) Verify 'jq .version package-lock.json' matches 'jq .version package.json'. Do NOT touch any source files.", permission_mode="bypassPermissions"]

    impl_p1_tests [prompt="Phase 1b — Fix spawn-morty tests and suppress ESLint warnings (ticket 24a9b944). In extension/: 1) Fix 4 failing tests in tests/spawn-morty.test.js — failures are test harness issues (Promise resolution in error handlers), not production bugs. 2) Suppress ~98 no-sync-in-async ESLint warnings by adding '// eslint-disable-next-line pickle/no-sync-in-async -- intentional blocking call' to each intentional sync call in async context. These are deliberate — orchestration code needs synchronous state reads before spawning workers. 3) Verify: 'npm test' exits 0 with 0 failures AND 'npx eslint src/ --max-warnings=-1' exits 0.", permission_mode="bypassPermissions"]

    verify_p1 [shape=parallelogram, tool_command="cd extension && npm test 2>&1 && npx eslint src/ --max-warnings=-1 2>&1 && npm audit --audit-level=high 2>&1", goal_gate=true, retry_target="impl_p1_lockfile", max_visits=3]
    check_p1 [shape=diamond]
    review_p1 [class="review", prompt="Review Phase 1 (Build Hygiene): Verify package-lock.json is synced, flatted CVE assessed correctly, spawn-morty test fixes are correct (not just silencing), ESLint suppressions are on genuinely intentional sync calls (not masking bugs). Check: no new dependencies added, no source logic changed, suppressions have explanatory comments. List issues with file:line."]
    simplify_p1 [prompt="Simplify Phase 1: Review ESLint disable comments for redundancy or inconsistent formatting. Ensure suppress comments follow pattern '// eslint-disable-next-line pickle/no-sync-in-async -- intentional blocking call'. Remove any duplicate suppressions. Preserve all test fixes and functionality."]
    reverify_p1 [shape=parallelogram, tool_command="cd extension && npm test 2>&1 && npx eslint src/ --max-warnings=-1 2>&1", goal_gate=true, retry_target="simplify_p1", max_visits=3]
    check_clean_p1 [shape=diamond]

    // ========== PHASE 2: Atomic State Manager (F5-F8) ==========

    impl_p2_statemanager [class="critical", prompt="Phase 2a — Implement StateManager class (ticket 82d58873). Create extension/src/services/state-manager.ts with: 1) StateManager.read(statePath): parse JSON, validate schema_version (migrate undefined->1, log migration), execute recovery protocol (orphan tmpfiles: check .tmp.* validity, promote if valid+newer iteration, else delete; stale active flag: check PID liveness via process.kill(pid,0), clear if dead). 2) StateManager.update(statePath, mutator): acquire file-based lock (O_CREAT|O_EXCL on .lock file), read current state, apply mutator, write via existing writeStateFile pattern (tmpfile+rename), release lock in finally block. 3) StateManager.transaction(paths, mutator): lock all paths (ordered to prevent deadlock), read all, apply mutator, write all — if any write fails, rollback previous files to originals. 4) StateManager.forceWrite(statePath, state): write WITHOUT lock (for crash-path signal/error handlers). Best-effort, never throws. Add StateManagerOptions to types/index.ts: maxLockRetries=10, baseLockDelayMs=100, lockJitter=true, staleLockTimeoutMs=30000, schemaVersion=1. Add StateError (codes: MISSING, CORRUPT, SCHEMA_MISMATCH, LOCK_FAILED, WRITE_FAILED), TransactionError, LockError classes. Add State.schema_version and State.pid fields. Create tests/state-manager.test.js: read valid/missing/corrupt, recovery protocol, update with lock, forceWrite while locked, transaction success/rollback, schema migration. Use existing writeStateFile from pickle-utils.ts:543-551.", permission_mode="bypassPermissions"]

    verify_p2a [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="impl_p2_statemanager", max_visits=3]
    check_p2a [shape=diamond]

    split_p2 [shape=component, max_parallel=1, join_policy="wait_all", error_policy="fail_fast"]

    impl_p2_migrate [class="critical", prompt="Phase 2b — Migrate all state.json writers to StateManager (ticket 5ab924c5). Migrate 61 call sites across 11 files per F6 inventory: CATEGORY 1 (StateManager.update): stop-hook.ts (4: lines 193,245,259,305), cancel.ts (2: 48,71), setup.ts (2: 209,250), jar-utils.ts (1: 76), pickle-utils.ts/updateState (1: 596), retry-ticket.ts (1: 82), mux-runner.ts (15 state.json calls). CATEGORY 2 (StateManager.transaction): microverse-runner.ts (10 state.json + 1 mvPath), microverse-state.ts (1: 119). CATEGORY 3 (forceWrite — crash-path bypass): mux-runner.ts:494, microverse-runner.ts:272, jar-runner.ts:186 — mark with eslint-disable comment. EXCLUDED (non-state): jar-runner.ts metaPath (7), rate_limit_wait.json (2), circuit-breaker.ts cbPath (1). Error propagation per PRD table: stop-hook=fail-open, mux-runner=retry-then-deactivate, setup/cancel=proceed-without-lock, etc. Create ESLint rule no-raw-state-write.", permission_mode="bypassPermissions"]

    impl_p2_sessions [prompt="Phase 2c — Harden sessions map locking (ticket 1d520024). In extension/src/services/pickle-utils.ts: Replace withSessionMapLock current fixed-50ms-retry that degrades to no-lock after 3s (line 390-393) with withRetryLock(): exponential backoff (base 100ms, jitter), configurable staleLockTimeoutMs (default 30s), NEVER silently fall through. On maxRetries exhausted: throw LockError. BEHAVIORAL CHANGE: setup.ts catches LockError from addToSessionMap, logs warning, proceeds without lock. cancel.ts catches LockError, logs warning, proceeds. All other callers propagate LockError. Add PID field to session entries for stale detection. Tests: pickle-utils.test.js — withRetryLock retries with backoff, throws after max, steals stale locks >30s.", permission_mode="bypassPermissions"]

    merge_p2 [shape=tripleoctagon, prompt="Verify both Phase 2 parallel tracks completed. Check for conflicts in pickle-utils.ts which both tracks may modify. Resolve merge conflicts preserving both migration and sessions lock changes."]

    verify_p2 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="impl_p2_migrate", max_visits=3]
    check_p2 [shape=diamond]
    review_p2 [class="review", prompt="Review Phase 2 (Atomic State Manager): CRITICAL. Verify: 1) All 61 call sites migrated per inventory (grep for raw writeStateFile — only 3 crash-path exceptions). 2) StateManager.update acquires lock, reads, mutates, writes atomically, releases in finally. 3) Transaction rollback tested. 4) forceWrite bypasses lock for crash paths. 5) Error propagation matches PRD table exactly. 6) Sessions lock: no silent fallthrough, exponential backoff, stale detection. 7) ESLint rule catches violations. 8) EXDEV: same-filesystem check or clear error. List issues with file:line."]
    simplify_p2 [prompt="Simplify Phase 2: Look for redundant lock/unlock patterns, verbose error handling, duplicate StateManager instantiation, unnecessary defensive checks. Ensure StateManager API is clean and consistent. Preserve all locking semantics and test coverage."]
    reverify_p2 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="simplify_p2", max_visits=3]
    check_clean_p2 [shape=diamond]

    // ========== PHASE 3: Process Lifecycle (F9-F12) ==========

    split_p3 [shape=component, max_parallel=1, join_policy="wait_all", error_policy="continue"]

    impl_p3_dispatch [prompt="Phase 3a — Fix dispatch stdin and spawn-refinement-team process lifecycle (ticket 64eeed6b). 1) In hooks/dispatch.ts: TWO EPIPE code paths must kill child — async error event (line 117-119) AND sync child.stdin.write() catch (line 125-127). Both call child.kill('SIGKILL'). 2) In bin/spawn-refinement-team.ts: delete process from activeWorkerProcs Set on close/error. On crash (exit!=0): kill all siblings via SIGTERM, log which worker crashed. Tests: dispatch.test.js — broken stdin triggers child.kill for both paths. spawn-refinement-team.test.js — 1-of-3 crash kills other 2, Set empty.", permission_mode="bypassPermissions"]

    impl_p3_fsync [prompt="Phase 3b — Add fsync before log close and fix handoff.txt race (ticket 38b76eb5). In bin/mux-runner.ts: 1) Add fs.fsyncSync(logFd) before fs.closeSync(logFd) for all log fds. 2) handoff.txt: wrap unlinkSync in try/catch (log warning on EACCES/ENOENT). Wrap renameSync in try/catch — on failure, fall back to writeFileSync (non-atomic, acceptable for non-critical file). If BOTH fail, log error but continue session. Tests: mux-runner.test.js — 3 scenarios: unlink EACCES (warning), rename fail (fallback write), both fail (error logged, continues).", permission_mode="bypassPermissions"]

    merge_p3 [shape=tripleoctagon, prompt="Verify both Phase 3 tracks completed. Check for import conflicts in mux-runner.ts."]

    verify_p3 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="impl_p3_dispatch", max_visits=3]
    check_p3 [shape=diamond]
    review_p3 [class="review", prompt="Review Phase 3 (Process Lifecycle): Verify: 1) Both EPIPE paths in dispatch.ts kill child. 2) spawn-refinement-team removes from Set on close/error, kills siblings on crash. 3) fsyncSync before closeSync on ALL log fds. 4) handoff.txt: unlink fail logged, rename fail uses writeFileSync fallback, both-fail logs but continues. 5) No new process leak vectors. List issues with file:line."]
    simplify_p3 [prompt="Simplify Phase 3: Check for redundant try/catch nesting in handoff.txt, unnecessary kill logic, verbose messages. Consolidate similar error handling. Preserve all process cleanup semantics."]
    reverify_p3 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="simplify_p3", max_visits=3]
    check_clean_p3 [shape=diamond]

    // ========== PHASE 4: Defensive Coding (F13-F20) ==========

    split_p4 [shape=component, max_parallel=1, join_policy="wait_all", error_policy="continue"]

    impl_p4_types [prompt="Phase 4a — Fix type coercion, git validation, timeout bounds (ticket 416d82bb). 1) F13: microverse-runner.ts — Number(state.worker_timeout_seconds) before comparison, so string '0' doesn't cause I/O thrashing. 2) F14: microverse-runner.ts ONLY (not mux-runner) — validate .git exists before auto-commit. Clear error 'not a git repository'. 3) F15: spawn-morty.ts — minimum 30s timeout floor, handle negative remaining. Tests: microverse.test.js — string '0' (no write), non-git cwd (error). spawn-morty.test.js — negative remaining (>=30), 5s remaining (===30).", permission_mode="bypassPermissions"]

    impl_p4_promise [prompt="Phase 4b — Fix promise token false positives and template validation (ticket d947cf56). 1) F16 CRITICAL REWRITE: extractAssistantContent in mux-runner.ts MUST CONTINUE INCLUDING result-type blocks (session final response for promise detection in classifyCompletion line 99-100). Actual vector: non-JSON plaintext from catch at mux-runner.ts:82-84. Fix: when line fails JSON.parse AND session uses stream-json (detected by any line parsing as JSON), SKIP non-JSON lines. 2) F20: template validation against directory listing of templates/ and commands/ (NOT hardcoded whitelist). Reject path traversal (/, \\, ..). Verify file exists. Tests: mux-runner.test.js — plaintext TASK_COMPLETED excluded, result-type included, assistant-type included, traversal rejected, unknown rejected, user command accepted.", permission_mode="bypassPermissions"]

    impl_p4_misc [prompt="Phase 4c — Fix CB history sync, activity logger retry, stop-hook input (ticket 3c236dbb). 1) F17: mux-runner.ts — write CB state inside StateManager transaction with state.json (line 785 independent from state write at 791 — combine). 2) F18: log-activity.ts — retry once after 500ms, buffer up to 100 events on failure, flush on next success. 3) F19: stop-hook.ts — empty stdin = approve silently, non-empty corrupted JSON = log warning with first 100 chars preview, still approve (fail-open). Tests: circuit-breaker.test.js — CB+state iteration match. activity-logger.test.js — ENOSPC retry+buffer. stop-hook.test.js — empty approves, corrupted warns.", permission_mode="bypassPermissions"]

    merge_p4 [shape=tripleoctagon, prompt="Verify all 3 Phase 4 tracks completed. Check for conflicts in mux-runner.ts (modified by p4_promise F16/F20 and p4_misc F17). Resolve preserving both changes."]

    verify_p4 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="impl_p4_types", max_visits=3]
    check_p4 [shape=diamond]
    review_p4 [class="review", prompt="Review Phase 4 (Defensive Coding): CRITICAL for F16. Verify: 1) result-type blocks STILL INCLUDED in extractAssistantContent. Only non-JSON plaintext excluded in stream-json mode. 2) F13: Number() coercion, not == or string compare. 3) F14: git check in microverse-runner ONLY. 4) F15: 30s floor, handles negative. 5) F17: CB inside StateManager transaction. 6) F18: retry+buffer bounded at 100. 7) F19: empty vs corrupted distinction. 8) F20: directory listing not hardcoded, traversal blocked. List issues with file:line."]
    simplify_p4 [prompt="Simplify Phase 4: Look for overly complex conditionals in F16 stream-json detection, redundant retry logic in F18, unnecessary abstractions in template validation. Consolidate where possible. Preserve all defensive behavior and tests."]
    reverify_p4 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="simplify_p4", max_visits=3]
    check_clean_p4 [shape=diamond]

    // ========== PHASE 5: Integration Testing (F21-F25) ==========

    impl_p5_harness [prompt="Phase 5a — Build integration test harness and concurrent state tests (ticket b2a377dc). Create tests/integration/. 1) F21: test-harness.js — mock runIteration (configurable: success, rate_limit, stall, error), real StateManager with real filesystem, tmpdir per test, cleanup on teardown. 2) F22: concurrent-state.test.js (STANDALONE — no harness dependency): 10 parallel StateManager.update() incrementing counter (final===10), 5 parallel addToSessionMap different cwds (all present), 2 same-cwd (conflict detected), stale active=true dead PID (auto-cleared). Node node:test runner.", permission_mode="bypassPermissions"]

    verify_p5a [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && node --test tests/integration/concurrent-state.test.js 2>&1", goal_gate=true, retry_target="impl_p5_harness", max_visits=3]
    check_p5a [shape=diamond]

    split_p5 [shape=component, max_parallel=1, join_policy="wait_all", error_policy="continue"]

    impl_p5_microverse [prompt="Phase 5b — Microverse convergence and crash recovery integration tests (ticket 16f95712). 1) F23: microverse-convergence.test.js — 5 iterations: 2 improved, 1 regressed (rollback), 1 stall (non-consecutive), 1 improved -> converged. Assert 5 entries, 3 accepted, 1 reverted, 1 stall. 2) crash-recovery.test.js — orphan tmpfile promoted/deleted, state written but microverse not (mismatch resolved), stale active+dead PID (cleared). 3) jar-batch.test.js — crash on ticket 4 (resume from 4), write fail on ticket 5 (skip to 6, marked failed).", permission_mode="bypassPermissions"]

    impl_p5_ratelimit [prompt="Phase 5c — Rate limit recovery and process cleanup integration tests (ticket 0118cacc). 1) F24: rate-limit-recovery.test.js — wait then user deactivates (clean break, active=false, no orphans), max_time expires during wait (limit_reached). 2) F25: process-cleanup.test.js — dispatch EPIPE kills child (both paths, no zombie), refinement worker 2-of-3 crash kills siblings (Set empty). 3) mux-loop.test.js — success/rate_limit/success (wait+resume), success/success/stall with CB open (deactivated), task completed with chain_meeseeks (template transitions).", permission_mode="bypassPermissions"]

    merge_p5 [shape=tripleoctagon, prompt="Verify both Phase 5 integration test tracks completed. Run all integration tests to check for isolation issues (shared tmpdir, port conflicts)."]

    verify_p5 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && node --test tests/integration/*.test.js 2>&1 && npm test 2>&1", goal_gate=true, retry_target="impl_p5_microverse", max_visits=3]
    check_p5 [shape=diamond]
    review_p5 [class="review", prompt="Review Phase 5 (Integration Testing): Verify: 1) Harness isolates tests (tmpdir, cleanup). 2) Concurrent state: 10 real-filesystem parallel writers, assert atomicity. 3) Microverse: all 5 outcomes covered. 4) Crash recovery: orphan tmpfile, cross-file mismatch, stale PID. 5) Jar-batch: resume and skip-on-failure. 6) Rate limit: cancel-during-wait, timeout-during-wait. 7) Process cleanup: both EPIPE paths, sibling kill. 8) No flaky timing (deterministic mocks). List issues with file:line."]
    simplify_p5 [prompt="Simplify Phase 5: Look for duplicated setup/teardown across integration tests, verbose assertions, helpers that could be shared via harness. Consolidate common patterns. Preserve all scenarios and assertions."]
    reverify_p5 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && node --test tests/integration/*.test.js 2>&1 && npm test 2>&1", goal_gate=true, retry_target="simplify_p5", max_visits=3]
    check_clean_p5 [shape=diamond]

    // ========== PHASE 6: Low-Priority Hardening (F26-F31) ==========

    split_p6 [shape=component, max_parallel=1, join_policy="wait_all", error_policy="continue"]

    impl_p6_caps [prompt="Phase 6a — Cap array growth and add engines field (ticket 83cf631f). 1) F26: circuit-breaker.ts — cap history at 1000 entries, shift oldest on overflow. 2) F27: microverse-state.ts — cap failed_approaches at 100, shift oldest. 3) F28: package.json — add engines: { node: '>=20.0.0' } (not 18, node --test stabilized in 20). Tests: circuit-breaker.test.js — 1001 transitions, length===1000. microverse.test.js — 101 approaches, length===100, oldest trimmed.", permission_mode="bypassPermissions"]

    impl_p6_docs [prompt="Phase 6b — Document ESLint rules and add schema version validation (ticket ffadea9c). 1) F29: Create extension/ESLINT_RULES.md documenting all 12 custom rules: name, what it catches, why, violation/fix examples. Include no-raw-state-write and no-sync-in-async. 2) F30: state-manager.ts — schema validation on load: undefined migrates to 1 (add field only, log). schema_version > current throws SCHEMA_MISMATCH. Old code ignores unknown fields (safe rollback). Tests: state-manager.test.js — undefined migrates (logged), v1 loads normally, future version throws.", permission_mode="bypassPermissions"]

    impl_p6_utility [prompt="Phase 6c — Extract safeErrorMessage utility (ticket 85cdc42f). F31: Add safeErrorMessage(err: unknown): string to pickle-utils.ts. Returns err.message if Error, String(err) otherwise. Never throws. Replace 65 inline 'err instanceof Error ? err.message : String(err)' across 26 files. EXCLUSION: Do NOT replace patterns inspecting .code or error subtypes (e.g., 'err instanceof Error && err.code === ENOENT') — those need the full Error object. Review each site individually. Tests: pickle-utils.test.js — null, Error('x'), 42, undefined.", permission_mode="bypassPermissions"]

    merge_p6 [shape=tripleoctagon, prompt="Verify all 3 Phase 6 tracks completed. Check safeErrorMessage doesn't conflict with Phase 2-4 error handling. Verify ESLINT_RULES.md covers no-raw-state-write from Phase 2."]

    verify_p6 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="impl_p6_caps", max_visits=3]
    check_p6 [shape=diamond]
    review_p6 [class="review", prompt="Review Phase 6 (Low-Priority Hardening): Verify: 1) Array caps use shift() for FIFO. 2) engines >=20.0.0. 3) ESLINT_RULES.md covers all 12 rules. 4) Schema migration additive only. 5) safeErrorMessage: 65 replacements across 26 files — spot-check 5+. NO .code patterns replaced. 6) No import cycles. List issues with file:line."]
    simplify_p6 [prompt="Simplify Phase 6: Check safeErrorMessage consistency. Look for remaining inline patterns that should be replaced (excluding .code inspections). Verify ESLINT_RULES.md is concise. Preserve all functionality."]
    reverify_p6 [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npm test 2>&1", goal_gate=true, retry_target="simplify_p6", max_visits=3]
    check_clean_p6 [shape=diamond]

    // ========== RELEASE GATE ==========

    impl_release [prompt="Final release gate (ticket eb5913e3). 1) Bump version in extension/package.json and package-lock.json to 1.15.0. 2) Run full gate: cd extension && npx tsc --noEmit && npx eslint src/ --max-warnings=-1 && npx tsc && npm test && npm audit --audit-level=high. 3) Verify git status clean (compiled JS matches TS). 4) Verify all 31 findings addressed. 5) Run bash install.sh to deploy. Do NOT create git tag or GitHub release — requires human approval.", permission_mode="bypassPermissions"]

    verify_release [shape=parallelogram, tool_command="cd extension && npx tsc --noEmit 2>&1 && npx eslint src/ --max-warnings=-1 2>&1 && npx tsc 2>&1 && npm test 2>&1 && npm audit --audit-level=high 2>&1", goal_gate=true, retry_target="impl_release", max_visits=3]
    check_release [shape=diamond]


    // ========== EDGES ==========

    // Dependency setup (runs before any impl/verify)
    start -> setup_deps
    setup_deps -> impl_p1_lockfile

    // Phase 1: Build Hygiene
    impl_p1_lockfile -> impl_p1_tests
    impl_p1_tests -> verify_p1
    verify_p1 -> check_p1
    check_p1 -> review_p1 [condition="outcome=success", weight=2]
    check_p1 -> impl_p1_lockfile [condition="outcome=fail"]
    review_p1 -> simplify_p1
    simplify_p1 -> reverify_p1
    reverify_p1 -> check_clean_p1
    check_clean_p1 -> impl_p2_statemanager [condition="outcome=success", weight=2]
    check_clean_p1 -> simplify_p1 [condition="outcome=fail"]

    // Phase 2a: StateManager class
    impl_p2_statemanager -> verify_p2a
    verify_p2a -> check_p2a
    check_p2a -> split_p2 [condition="outcome=success", weight=2]
    check_p2a -> impl_p2_statemanager [condition="outcome=fail"]

    // Phase 2b-c: Parallel migrate + sessions lock
    split_p2 -> impl_p2_migrate
    split_p2 -> impl_p2_sessions
    impl_p2_migrate -> merge_p2
    impl_p2_sessions -> merge_p2
    merge_p2 -> verify_p2
    verify_p2 -> check_p2
    check_p2 -> review_p2 [condition="outcome=success", weight=2]
    check_p2 -> impl_p2_migrate [condition="outcome=fail"]
    review_p2 -> simplify_p2
    simplify_p2 -> reverify_p2
    reverify_p2 -> check_clean_p2
    check_clean_p2 -> split_p3 [condition="outcome=success", weight=2]
    check_clean_p2 -> simplify_p2 [condition="outcome=fail"]

    // Phase 3: Parallel dispatch + fsync
    split_p3 -> impl_p3_dispatch
    split_p3 -> impl_p3_fsync
    impl_p3_dispatch -> merge_p3
    impl_p3_fsync -> merge_p3
    merge_p3 -> verify_p3
    verify_p3 -> check_p3
    check_p3 -> review_p3 [condition="outcome=success", weight=2]
    check_p3 -> impl_p3_dispatch [condition="outcome=fail"]
    review_p3 -> simplify_p3
    simplify_p3 -> reverify_p3
    reverify_p3 -> check_clean_p3
    check_clean_p3 -> split_p4 [condition="outcome=success", weight=2]
    check_clean_p3 -> simplify_p3 [condition="outcome=fail"]

    // Phase 4: Parallel types + promise + misc
    split_p4 -> impl_p4_types
    split_p4 -> impl_p4_promise
    split_p4 -> impl_p4_misc
    impl_p4_types -> merge_p4
    impl_p4_promise -> merge_p4
    impl_p4_misc -> merge_p4
    merge_p4 -> verify_p4
    verify_p4 -> check_p4
    check_p4 -> review_p4 [condition="outcome=success", weight=2]
    check_p4 -> impl_p4_types [condition="outcome=fail"]
    review_p4 -> simplify_p4
    simplify_p4 -> reverify_p4
    reverify_p4 -> check_clean_p4
    check_clean_p4 -> impl_p5_harness [condition="outcome=success", weight=2]
    check_clean_p4 -> simplify_p4 [condition="outcome=fail"]

    // Phase 5a: Harness + concurrent tests
    impl_p5_harness -> verify_p5a
    verify_p5a -> check_p5a
    check_p5a -> split_p5 [condition="outcome=success", weight=2]
    check_p5a -> impl_p5_harness [condition="outcome=fail"]

    // Phase 5b-c: Parallel microverse + ratelimit
    split_p5 -> impl_p5_microverse
    split_p5 -> impl_p5_ratelimit
    impl_p5_microverse -> merge_p5
    impl_p5_ratelimit -> merge_p5
    merge_p5 -> verify_p5
    verify_p5 -> check_p5
    check_p5 -> review_p5 [condition="outcome=success", weight=2]
    check_p5 -> impl_p5_microverse [condition="outcome=fail"]
    review_p5 -> simplify_p5
    simplify_p5 -> reverify_p5
    reverify_p5 -> check_clean_p5
    check_clean_p5 -> split_p6 [condition="outcome=success", weight=2]
    check_clean_p5 -> simplify_p5 [condition="outcome=fail"]

    // Phase 6: Parallel caps + docs + utility
    split_p6 -> impl_p6_caps
    split_p6 -> impl_p6_docs
    split_p6 -> impl_p6_utility
    impl_p6_caps -> merge_p6
    impl_p6_docs -> merge_p6
    impl_p6_utility -> merge_p6
    merge_p6 -> verify_p6
    verify_p6 -> check_p6
    check_p6 -> review_p6 [condition="outcome=success", weight=2]
    check_p6 -> impl_p6_caps [condition="outcome=fail"]
    review_p6 -> simplify_p6
    simplify_p6 -> reverify_p6
    reverify_p6 -> check_clean_p6
    check_clean_p6 -> impl_release [condition="outcome=success", weight=2]
    check_clean_p6 -> simplify_p6 [condition="outcome=fail"]

    // Release gate
    impl_release -> verify_release
    verify_release -> check_release
    check_release -> done [condition="outcome=success", weight=2]
    check_release -> impl_release [condition="outcome=fail"]
}
